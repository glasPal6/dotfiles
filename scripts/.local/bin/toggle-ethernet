#!/bin/bash

NETDIR="/etc/systemd/network"
STATIC="20-ethernet-static.network"
DHCP="20-ethernet-dhcp.network"
STATIC_DISABLED="20-ethernet-static.disabled"
DHCP_DISABLED="20-ethernet-dhcp.disabled"

if [ -f "$NETDIR/$STATIC_DISABLED" ]; then
    # Static config is disabled, so DHCP is active. Switch to static.
    echo "Switching to STATIC mode..."
    sudo mv "$NETDIR/$DHCP" "$NETDIR/$DHCP_DISABLED"
    sudo mv "$NETDIR/$STATIC_DISABLED" "$NETDIR/$STATIC"
elif [ -f "$NETDIR/$DHCP_DISABLED" ]; then
    # DHCP config is disabled, so static is active. Switch to DHCP.
    echo "Switching to DHCP mode..."
    sudo mv "$NETDIR/$STATIC" "$NETDIR/$STATIC_DISABLED"
    sudo mv "$NETDIR/$DHCP_DISABLED" "$NETDIR/$DHCP"
else
    echo "Error: Could not determine current mode. Please check your config files."
    exit 1
fi

echo "Reloading networkd..."
sudo systemctl restart systemd-networkd
