# Dynamic theme colors
config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

# Font
font-family = "JetBrainsMono Nerd Font"
font-style = Regular
font-size = 9

# Window
window-theme = ghostty
window-padding-x = 14
window-padding-y = 14
confirm-close-surface=false
resize-overlay = never
gtk-toolbar-style = flat

# Cursor styling
cursor-style = "block"
cursor-style-blink = false

# Cursor styling + SSH session terminfo
# (all shell integration options must be passed together)
shell-integration-features = no-cursor,ssh-env

# Slowdown mouse scrolling
# mouse-scroll-multiplier = 0.95

# Keybindings
keybind = clear

# Clipboard
keybind = copy=copy_to_clipboard
keybind = paste=paste_from_clipboard
keybind = shift+insert=paste_from_clipboard
keybind = control+insert=copy_to_clipboard
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

# Font Size
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl++=increase_font_size:1
keybind = ctrl+-=decrease_font_size:1
keybind = ctrl+0=reset_font_size

# Config & Inspector
keybind = ctrl+,=open_config
keybind = ctrl+shift+,=reload_config
keybind = ctrl+shift+i=inspector:toggle

# Window Management
keybind = ctrl+enter=toggle_fullscreen
keybind = ctrl+shift+n=new_window
keybind = alt+f4=close_window
keybind = ctrl+shift+q=quit

# Tab Management
keybind = ctrl+alt+t=new_tab
keybind = ctrl+alt+w=close_tab:this
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab
keybind = ctrl+shift+arrow_left=previous_tab
keybind = ctrl+shift+arrow_right=next_tab
keybind = ctrl+page_down=next_tab
keybind = ctrl+page_up=previous_tab
keybind = alt+digit_1=goto_tab:1
keybind = alt+digit_2=goto_tab:2
keybind = alt+digit_3=goto_tab:3
keybind = alt+digit_4=goto_tab:4
keybind = alt+digit_5=goto_tab:5
keybind = alt+digit_6=goto_tab:6
keybind = alt+digit_7=goto_tab:7
keybind = alt+digit_8=goto_tab:8
keybind = alt+1=goto_tab:1
keybind = alt+2=goto_tab:2
keybind = alt+3=goto_tab:3
keybind = alt+4=goto_tab:4
keybind = alt+5=goto_tab:5
keybind = alt+6=goto_tab:6
keybind = alt+7=goto_tab:7
keybind = alt+8=goto_tab:8
keybind = alt+9=last_tab

# Split Management
keybind = ctrl+alt+s=new_split:down
keybind = ctrl+alt+v=new_split:right
keybind = ctrl+shift+enter=toggle_split_zoom
keybind = super+ctrl+bracket_left=goto_split:previous
keybind = super+ctrl+bracket_right=goto_split:next
keybind = alt+arrow_down=goto_split:down
keybind = alt+arrow_left=goto_split:left
keybind = alt+arrow_right=goto_split:right
keybind = alt+arrow_up=goto_split:up

# Split Resizing
keybind = alt+shift+arrow_down=resize_split:down,100
keybind = alt+shift+arrow_left=resize_split:left,100
keybind = alt+shift+arrow_right=resize_split:right,100
keybind = alt+shift+arrow_up=resize_split:up,100
keybind = ctrl+alt+arrow_down=resize_split:down,10
keybind = ctrl+alt+arrow_left=resize_split:left,10
keybind = ctrl+alt+arrow_right=resize_split:right,10
keybind = ctrl+alt+arrow_up=resize_split:up,10

# Selection & Scrolling
keybind = ctrl+shift+a=select_all
keybind = shift+end=scroll_to_bottom
keybind = shift+home=scroll_to_top
keybind = shift+page_down=scroll_page_down
keybind = shift+page_up=scroll_page_up
keybind = shift+arrow_down=adjust_selection:down
keybind = shift+arrow_left=adjust_selection:left
keybind = shift+arrow_right=adjust_selection:right
keybind = shift+arrow_up=adjust_selection:up

# Prompt Navigation
keybind = ctrl+shift+page_down=jump_to_prompt:1
keybind = ctrl+shift+page_up=jump_to_prompt:-1
# Move backward a word
keybind = shift+arrow_left=esc:b
# Move forward a word
keybind = shift+arrow_right=esc:f

# Command Palette
keybind = ctrl+shift+p=toggle_command_palette

# Screen File Actions
keybind = super+ctrl+shift+j=write_screen_file:copy
keybind = ctrl+alt+shift+j=write_screen_file:open
keybind = ctrl+shift+j=write_screen_file:paste


