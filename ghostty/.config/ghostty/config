# keybind = ctrl+space>z=toggle_split_zoom
# keybind = ctrl+space>t=new_tab
# keybind = ctrl+space>enter=new_window
# # keybind = ctrl+space>T=toggle_tab_overview
# keybind = ctrl+space>n=next_tab
# keybind = ctrl+space>p=previous_tab

# Pane navigation (leader + arrows)
# keybind = ctrl+shift+left=goto_split:left
# keybind = ctrl+shift+down=goto_split:down
# keybind = ctrl+shift+up=goto_split:up
# keybind = ctrl+shift+right=goto_split:right
