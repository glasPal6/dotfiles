# Theme
theme = Catppuccin Mocha

# Font
font-family = "JetBrains Mono"
font-style = Regular
font-size = 12

# Window
window-theme = ghostty
window-decoration = true
window-show-tab-bar = always
gtk-tabs-location = top
window-padding-x = 14
window-padding-y = 14
confirm-close-surface = false
resize-overlay = never
gtk-toolbar-style = flat

# Cursor styling
cursor-style = "block"
cursor-style-blink = false

# Cursor styling + SSH session terminfo
# (all shell integration options must be passed together)
shell-integration-features = no-cursor,ssh-env

# Keyboard bindings (WezTerm-style leader = ctrl+space)
keybind = f11=toggle_fullscreen

# Leader: ctrl+space sequences
keybind = ctrl+space>q=close_all_windows
keybind = ctrl+space>s=new_split:down
keybind = ctrl+space>v=new_split:right
keybind = ctrl+space>z=toggle_split_zoom
keybind = ctrl+space>t=new_tab
keybind = ctrl+space>T=toggle_tab_overview
keybind = ctrl+space>n=next_tab
keybind = ctrl+space>p=previous_tab

# Clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+c=copy_to_clipboard

# Resize splits (rough match)
keybind = super+control+shift+alt+arrow_down=resize_split:down,5
keybind = super+control+shift+alt+arrow_up=resize_split:up,5
keybind = super+control+shift+alt+arrow_left=resize_split:left,5
keybind = super+control+shift+alt+arrow_right=resize_split:right,5

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Mac
macos-option-as-alt = true
