# keybind = ctrl+space>]=goto_split:next

# Clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+c=copy_to_clipboard

# Resize splits (leader + shift + arrows)
# keybind = ctrl+space>shift+left=resize_split:left,10
