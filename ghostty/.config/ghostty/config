# keybind = ctrl+space>shift+up=resize_split:up,10
# keybind = ctrl+space>shift+right=resize_split:right,10

# Slowdown mouse scrolling
# mouse-scroll-multiplier = 0.95

# Mac
macos-option-as-alt = true
